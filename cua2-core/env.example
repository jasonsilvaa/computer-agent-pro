# Environment Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- LOCAL MODE (default, no API keys) ---
# Uses Ollama + local desktop. Set DESKTOP_API_URL, OLLAMA_BASE_URL, VNC_URL
# when running in Docker (docker-compose sets these).

# --- CLOUD MODE (optional) ---
# HF_TOKEN=your_huggingface_token_here   # For HuggingFace inference models
# E2B_API_KEY=your_e2b_api_key_here       # For E2B cloud sandboxes

# Agent Configuration
AGENT_TIMEOUT=300
MAX_CONCURRENT_TASKS=5

# Logging
LOG_LEVEL=INFO
