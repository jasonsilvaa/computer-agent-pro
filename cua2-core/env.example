# Environment Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Runtime Mode
# original = closest to upstream (requires HF_TOKEN + E2B_API_KEY)
# local    = Ollama + local desktop
APP_MODE=original

# --- ORIGINAL-COMPATIBLE MODE ---
# HF_TOKEN=your_huggingface_token_here
# E2B_API_KEY=your_e2b_api_key_here

# --- LOCAL MODE ---
# Uses Ollama + local desktop. These are set automatically by docker-compose.
# DESKTOP_API_URL=http://desktop:5000
# OLLAMA_BASE_URL=http://ollama:11434
# VNC_URL=http://localhost:6080/vnc.html
# DESKTOP_WIDTH=1280
# DESKTOP_HEIGHT=720

# Agent Configuration
AGENT_TIMEOUT=300
MAX_CONCURRENT_TASKS=5

# Logging
LOG_LEVEL=INFO
